{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    //"allowJs": true,
    //"checkJs": false,
    "noEmitOnError": true,
    // ÖNEMLİ: Eğer ileride @types/jest veya @types/express gibi yeni tip paketleri kurarsan, TS'in tanıması için adlarını bu diziye eklemelisin.
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
