# ==============================================================================
# AARO ERP MCP Server - Environment Configuration Data
# ==============================================================================

# TRANSPORT MODE
# 'sse' : Use Express based Server-Sent Events (For remote / web connectivity).
# 'stdio' : Standard Node.js process I/O (For local Claude Desktop direct use).
TRANSPORT=sse

# PORT
# The port number on which the SSE Express server will run (Default is 3000)
PORT=3000

# API TOKENS (Optional for global override)
# If provided, all requests going to ERP will use this token by default unless changed.
# Alternatively, clients can pass 'Authorization: Bearer <token>' in their HTTP headers.
API_TOKEN=ornekGlobalToken123
ERP_BEARER_TOKEN=ornekGlobalToken123

# LOGGING
# LOG_LEVEL: error | warn | info | debug (Default: info)
LOG_LEVEL=info
