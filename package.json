{
  "name": "mcpserver",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "logs": "powershell -Command \"[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; if (!(Test-Path logs)) { New-Item -ItemType Directory -Path logs }; if (!(Test-Path logs/requests.log)) { New-Item -ItemType File -Path logs/requests.log }; Get-Content -Path logs/requests.log -Wait -Tail 50\"",
    "generate": "orval --config ./orval.config.ts && node scripts/fix-esm-imports.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fuse.js": "^7.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "orval": "^8.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
